# Root .gitignore for AI CV Manager

# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables
.env
backend/.env
frontend/.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# Build outputs
dist/
build/
frontend/dist/
backend/dist/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
backend/logs/

# Prisma
backend/prisma/dev.db
backend/prisma/dev.db-journal

# Editor and OS specific files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Assets
assets/*.png
assets/*.jpg
assets/*.svg
!assets/.keep
